generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model homemaid {
  id                     Int               @id @default(autoincrement())
  OfficeName             String?           @db.VarChar(100)
  Externalofficecopy     String?           @db.VarChar(40)
  Name                   String?           @db.VarChar(1024)
  Nationalitycopy        String?           @db.VarChar(1024)
  Religion               String?           @db.VarChar(1024)
  maritalstatus          String?           @db.VarChar(1024)
  children               Int?
  weight                 Int?
  height                 Int?
  Education              String?           @db.VarChar(27)
  Experience             String?           @db.VarChar(1024)
  ExperienceYears        String?           @db.VarChar(1024)
  ExperiencePlaces       String?           @db.VarChar(51)
  Passportnumber         String?           @db.VarChar(1024)
  PassportEnd            DateTime?         @db.DateTime(0)
  PassportStart          DateTime?         @db.DateTime(0)
  OldPeopleCare          Int?              @db.TinyInt
  ArabicLanguageLevel    String?           @db.VarChar(522)
  EnglishLanguageLevel   String?           @db.VarChar(522)
  Salary                 String?           @db.VarChar(20)
  LaundryLevel           String?           @db.VarChar(522)
  IroningLevel           String?           @db.VarChar(522)
  CleaningLevel          String?           @db.VarChar(522)
  CookingLevel           String?           @db.VarChar(522)
  SewingLevel            String?           @db.VarChar(522)
  BabySitterLevel        String?           @db.VarChar(522)
  dateofbirth            DateTime?         @db.DateTime(0)
  ages                   String?           @db.VarChar(1024)
  clientphonenumber      String?           @db.VarChar(19)
  phone                  String?           @db.VarChar(1024)
  officeID               Int?
  Picture                Json?
  Nationality            Json?
  age                    Int?
  flag                   Json?
  bookingstatus          String?           @db.VarChar(1024)
  experienceType         String?           @db.VarChar(100)
  FullPicture            Json?
  professionId           Int?
  displayOrder           Int               @default(0)
  job                    String?           @db.VarChar(32)
  createdAt              DateTime          @default(now()) @db.DateTime(0)
  updatedAt              DateTime          @default(now()) @updatedAt @db.Timestamp(0)
  isExternal             Boolean           @default(false)
  Passportphoto          String?           @db.VarChar(522)
  transferSponsorShipsId Int?
  washingLevel           String?           @db.VarChar(100)
  childcareLevel         String?           @db.VarChar(100)
  elderlycareLevel       String?           @db.VarChar(100)
  isApproved             Boolean           @default(false)
  contractType           String            @default("recruitment") @db.VarChar(124)
  notes                  String?           @db.VarChar(255)
  Client                 Client[]
  cancelledOrders        cancelledOrders[]
  inHouseLocation        inHouseLocation[]
  rejectedOrders         rejectedOrders[]

  @@index([professionId])
  @@index([bookingstatus(length: 768)], map: "idx_homemaid_bookingstatus")
  @@index([Name(length: 768)], map: "idx_homemaid_name")
  @@index([Passportnumber(length: 768)], map: "idx_homemaid_passport")
  @@index([phone(length: 768)], map: "idx_homemaid_phone")
  @@index([officeID], map: "officeid")
}

model DeliveryDetails {
  id             Int       @id @default(autoincrement())
  deliveryDate   DateTime? @db.DateTime(0)
  deliveryTime   String?   @db.VarChar(100)
  deliveryFile   String?   @db.VarChar(255)
  deliveryNotes  String?   @db.VarChar(255)
  cost           Decimal?  @db.Decimal(10, 2)
  newOrderId     Int?
  isDelivered    Boolean?  @default(false)
  userId         Int?
  createdAt      DateTime? @default(now()) @db.DateTime(0)
  updatedAt      DateTime? @default(now()) @updatedAt @db.DateTime(0)
  completionDate DateTime? @default(now()) @db.DateTime(0)
  neworder       neworder? @relation(fields: [newOrderId], references: [id], map: "fk_deliverydetails_neworder")
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_deliverydetails_user")

  @@index([deliveryDate], map: "idx_deliverydetails_date")
  @@index([isDelivered], map: "idx_deliverydetails_isdelivered")
  @@index([newOrderId], map: "idx_deliverydetails_neworder")
  @@index([userId], map: "idx_deliverydetails_user")
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String    @unique(map: "name")
  permissions Json?
  createdAt   DateTime? @default(now()) @db.DateTime(0)
  updatedAt   DateTime? @default(now()) @updatedAt @db.DateTime(0)
  order       Int?
}

model User {
  phonenumber        String?           @unique @db.VarChar(19)
  id                 Int               @id @default(autoincrement())
  admin              Boolean?          @default(false)
  pictureurl         String?           @db.LongText
  username           String            @unique(map: "username")
  password           String
  role               String?
  idnumber           Int?              @unique
  roleId             Int?
  createdAt          DateTime          @default(now()) @db.DateTime(0)
  updatedAt          DateTime          @default(now()) @updatedAt @db.DateTime(0)
  email              String?
  assignedComplaints Complaint[]       @relation("ComplaintAssignedTo")
  createdComplaints  Complaint[]       @relation("ComplaintCreatedBy")
  DeliveryDetails    DeliveryDetails[]

  @@index([username], map: "idx_username")
}

model tasks {
  id              Int       @id @default(autoincrement())
  userId          Int
  description     String    @db.Text
  taskDeadline    DateTime  @db.DateTime(0)
  createdAt       DateTime  @default(now()) @db.DateTime(0)
  updatedAt       DateTime  @default(now()) @updatedAt @db.DateTime(0)
  isCompleted     Boolean?  @default(false)
  Title           String?   @db.VarChar(255)
  assignedBy      Int?
  priority        String?   @db.VarChar(50)
  isActive        Boolean?  @default(true)
  isRepeating     Boolean?  @default(false)
  repeatType      String?   @db.VarChar(20)
  repeatInterval  Int?      @default(1)
  repeatStartDate DateTime? @db.DateTime(0)
  repeatEndDate   DateTime? @db.DateTime(0)
  repeatEndType   String?   @db.VarChar(20)
  repeatCount     Int?      @default(1)
  repeatDays      Json?
  repeatTime      String?   @db.VarChar(10)
  completionDate  DateTime? @db.DateTime(0)
  completionNotes String?   @db.VarChar(500)
  parentTaskId    Int?
  notificationsId Int?

  @@index([parentTaskId], map: "fk_tasks_parentTaskId")
  @@index([assignedBy])
  @@index([notificationsId], map: "tasks_notificationsId_fkey")
  @@index([userId], map: "userId")
}

model weeklyStatus {
  id          Int       @id @default(autoincrement())
  homeMaid_id Int
  status      String?   @db.VarChar(255)
  date        DateTime? @db.DateTime(0)
  createdAt   DateTime? @default(now()) @db.DateTime(0)
  updatedAt   DateTime? @default(now()) @updatedAt @db.DateTime(0)
  employee    String?   @db.VarChar(255)

  @@index([homeMaid_id], map: "homeMaid_id")
}

model notifications {
  id        Int       @id @default(autoincrement())
  message   String?   @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.DateTime(0)
  updatedAt DateTime? @default(now()) @updatedAt @db.DateTime(0)
  isRead    Boolean?  @default(false)
  userId    String?   @db.VarChar(100)
  title     String    @db.VarChar(55)
  type      String?   @db.VarChar(32)
  taskId    Int?      @unique

  @@index([id], map: "idx_notifications_id")
  @@index([userId], map: "userId")
}

model NotificationRead {
  id             Int      @id @default(autoincrement())
  notificationId Int
  userId         String
  readAt         DateTime @default(now()) @db.DateTime(0)

  @@unique([notificationId, userId])
  @@index([notificationId], map: "idx_notificationId")
  @@index([userId], map: "idx_userId")
}

model officemssages {
  id         Int       @id @default(autoincrement())
  title      String?   @db.VarChar(55)
  message    String?   @db.VarChar(255)
  createdAt  DateTime? @default(now()) @db.DateTime(0)
  updatedAt  DateTime? @default(now()) @updatedAt @db.DateTime(0)
  isRead     Boolean?  @default(false)
  officeName String?
  sender     String?   @db.VarChar(255)
  type       String    @db.VarChar(32)

  @@index([officeName], map: "fk_officeName")
}

model Template {
  id            Int       @id @default(autoincrement())
  title         String    @db.VarChar(255)
  content       String    @db.Text
  type          String    @db.VarChar(100)
  createdAt     DateTime? @default(now()) @db.DateTime(0)
  updatedAt     DateTime? @default(now()) @updatedAt @db.DateTime(0)
  dynamicFields String?   @db.Text
  defaultValues String?   @db.Text
}

model offices {
  id                        Int             @id @default(autoincrement())
  office                    String?         @unique(map: "office") @db.VarChar(512)
  Country                   String?         @db.VarChar(512)
  phoneNumber               String?
  password                  String?         @db.VarChar(255)
  office_id                 String?         @db.VarChar(255)
  url                       String?         @db.VarChar(512)
  musanadFinancialRecordsId Int?
  email                     String?
  language                  String          @default("eng") @db.VarChar(151)
  commission                Decimal?        @default(0.000000000000000000000000000000)
  CustomTimeline            CustomTimeline?

  @@index([musanadFinancialRecordsId], map: "offices_musanadFinancialRecordsId_fkey")
}

model Client {
  id                Int                 @id @default(autoincrement())
  isUser            Boolean?
  fullname          String?
  notes_date        DateTime?           @db.DateTime(0)
  email             String?             @unique(map: "email")
  phonenumber       String?             @unique(map: "phonenumber") @db.VarChar(15)
  password          String?             @db.VarChar(255)
  HomeMaidRecod     Int?
  Source            String?
  createdAt         DateTime?           @default(now()) @db.DateTime(0)
  nationalId        String?             @db.VarChar(30)
  city              String?             @db.VarChar(100)
  address           String?             @db.VarChar(100)
  AccountSystemLogs AccountSystemLogs[]
  HomeMaid          homemaid?           @relation(fields: [HomeMaidRecod], references: [id], map: "fk_client_homemaid")
  arrivals          arrivallist[]
  cancelledOrders   cancelledOrders[]
  externalHomedmaid externalHomedmaid[]
  rejectedOrders    rejectedOrders[]

  @@index([email], map: "idx_client_email")
  @@index([HomeMaidRecod], map: "idx_client_homemaid")
  @@index([phonenumber], map: "idx_client_phonenumber")
}

model notes {
  id        Int      @id @default(autoincrement())
  notes     String?  @db.VarChar(255)
  clientID  Int?
  createdAt DateTime @default(now()) @db.DateTime(0)
  updatedAt DateTime @updatedAt @db.DateTime(0)

  @@index([clientID], map: "notes_clientID_fkey")
}

model cashLogs {
  id        Int       @id @default(autoincrement())
  Status    String?   @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.DateTime(0)
  updatedAt DateTime? @updatedAt @db.DateTime(0)
  userId    String?   @db.VarChar(255)
  cashID    Int?

  @@index([cashID], map: "cashID")
  @@index([userId], map: "userId")
}

model systemUserLogs {
  id            Int       @id @default(autoincrement())
  actionType    String?   @db.VarChar(255)
  beneficiary   String?   @db.VarChar(255)
  action        String?   @db.VarChar(255)
  BeneficiaryId Int?
  pageRoute     String?   @db.VarChar(255)
  createdAt     DateTime? @default(now()) @db.DateTime(0)
  updatedAt     DateTime? @default(now()) @updatedAt @db.DateTime(0)
  userId        Int
  details       String    @db.VarChar(1024)

  @@index([userId], map: "userId")
}

model logs {
  id         Int       @id @default(autoincrement())
  Status     String?   @db.VarChar(255)
  createdAt  DateTime? @default(now()) @db.DateTime(0)
  updatedAt  DateTime? @default(now()) @updatedAt @db.DateTime(0)
  Details    String?   @db.Text
  reason     String?   @db.Text
  userId     String?   @db.VarChar(255)
  homemaidId Int?

  @@index([homemaidId], map: "homemaidId")
  @@index([userId], map: "userId")
}

model Session {
  id                Int                 @id @default(autoincrement())
  reason            String
  date              DateTime?           @db.DateTime(0)
  result            String?             @db.Text
  idnumber          Int
  createdAt         DateTime?           @default(now()) @db.DateTime(0)
  updatedAt         DateTime?           @default(now()) @updatedAt @db.DateTime(0)
  time              String?             @db.Text
  externalHomedmaid externalHomedmaid[]

  @@index([idnumber], map: "idnumber")
}

model Rating {
  id        Int       @id @default(autoincrement())
  idOrder   Int?
  isRated   Boolean?  @default(false)
  reason    String?   @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.DateTime(0)
  updatedAt DateTime? @default(now()) @updatedAt @db.DateTime(0)

  @@index([idOrder], map: "idOrder")
}

model neworder {
  id                       Int               @id @default(autoincrement())
  ClientName               String?           @db.VarChar(255)
  PhoneNumber              String?           @db.VarChar(15)
  clientID                 Int?
  HomemaidId               Int?              @unique(map: "HomemaidId")
  Nationalitycopy          String?           @db.VarChar(255)
  Name                     String?           @db.VarChar(255)
  Religion                 String?           @db.VarChar(255)
  Passportnumber           String?           @db.VarChar(255)
  clientphonenumber        String?           @db.VarChar(255)
  Picture                  Json?
  ExperienceYears          String?           @db.VarChar(255)
  maritalstatus            String?           @db.VarChar(255)
  Experience               String?           @db.VarChar(255)
  dateofbirth              String?           @db.VarChar(255)
  Nationality              Json?
  age                      Int?
  flag                     Json?
  phone                    String?           @db.VarChar(15)
  bookingstatus            String?           @db.VarChar(255)
  ages                     String?           @db.VarChar(255)
  createdAt                DateTime?         @default(now())
  updatedAt                DateTime?         @updatedAt
  updatedBy                String?           @db.VarChar(255)
  ReasonOfRejection        String?           @db.VarChar(255)
  HomemaidIdCopy           Int?
  nationalId               String?           @db.VarChar(30)
  profileStatus            String?           @db.VarChar(255)
  isHidden                 Boolean           @default(false)
  typeOfContract           String            @default("recruitment") @db.VarChar(23)
  PaymentMethod            String?           @db.VarChar(32)
  Installments             Int?
  Total                    Float?
  isContractEnded          Boolean           @default(false)
  orderDocument            String?           @db.VarChar(522)
  contract                 String?           @db.VarChar(522)
  isAvailable              Boolean           @default(true)
  paid                     Float?
  notes                    String?           @db.VarChar(255)
  DeliveryDetailsId        Int?
  clientAccountStatementId Int?
  visaId                   Int?
  ReasonOfCancellation     String?           @db.VarChar(255)
  foreignLaborApproval     Boolean?          @default(false)
  travelPermit             String?           @db.VarChar(255)
  medicalCheckFile         String?
  DeliveryDetails          DeliveryDetails[]
  arrivals                 arrivallist[]
  cancelledOrders          cancelledOrders[]
  visa                     visa?             @relation(fields: [visaId], references: [id])
  rejectedOrders           rejectedOrders[]
  tickets_details          tickets_details[]

  @@index([clientAccountStatementId], map: "fk_neworder_ClientAccountStatement")
  @@index([DeliveryDetailsId], map: "fk_neworder_DeliveryDetails")
  @@index([clientID], map: "neworder_clientID_fkey")
  @@index([visaId])
}

model visa {
  id          Int        @id @default(autoincrement())
  visaNumber  String?    @db.VarChar(255)
  gender      String?    @db.VarChar(255)
  profession  String?    @db.VarChar(255)
  visaFile    String?    @db.VarChar(512)
  nationality String?    @db.VarChar(255)
  clientID    Int?
  createdAt   DateTime?  @default(now()) @db.DateTime(0)
  updatedAt   DateTime?  @default(now()) @updatedAt @db.DateTime(0)
  orders      neworder[]

  @@index([clientID], map: "fk_visa_client")
}

model inHouseLocation {
  id         Int       @id @default(autoincrement())
  location   String    @db.VarChar(255)
  createdAt  DateTime? @default(now()) @db.DateTime(0)
  updatedAt  DateTime? @default(now()) @updatedAt @db.DateTime(0)
  quantity   Int?      @default(0)
  supervisor Int?
  homemaid   homemaid? @relation(fields: [supervisor], references: [id], onUpdate: NoAction, map: "fk_inhouse_supervisor")

  @@index([supervisor], map: "fk_inhouse_supervisor")
  @@index([location], map: "idx_location")
}

model emaillist {
  id         Int       @id @default(autoincrement())
  email      String?
  department String?
  createdAt  DateTime? @default(now()) @db.DateTime(0)
  updatedAt  DateTime? @default(now()) @updatedAt @db.DateTime(0)
  userId     Int?

  @@index([userId], map: "userId")
}

model arrivallist {
  id                          Int       @id @default(autoincrement())
  SponsorName                 String?
  InternalmusanedContract     String?
  SponsorIdnumber             Int?
  SponsorPhoneNumber          String?
  PassportNumber              String?
  KingdomentryDate            DateTime?
  DayDate                     DateTime  @default(now())
  WorkDuration                String?
  Cost                        String?
  HomemaIdnumber              Int?
  HomemaidName                String?
  Notes                       String?
  ArrivalCity                 String?
  DateOfApplication           DateTime?
  MusanadDuration             String?
  ExternalDateLinking         DateTime?
  ExternalOFficeApproval      DateTime?
  AgencyDate                  DateTime?
  EmbassySealing              DateTime?
  BookinDate                  DateTime?
  GuaranteeDurationEnd        DateTime?
  medicalCheckFile            String?   @db.VarChar(200)
  ticketFile                  String?   @db.VarChar(200)
  visaIssuanceDate            DateTime? @db.DateTime(0)
  receivingFile               String?   @db.VarChar(200)
  approvalPayment             String?   @db.VarChar(200)
  additionalfiles             Json?
  OrderId                     Int?
  externalmusanedContract     String?
  externalmusanadcontractfile String?
  externalOfficeStatus        String?   @db.VarChar(25)
  finaldestination            String?
  DeliveryDate                DateTime?
  ExternalStatusByoffice      String?
  DeliveryFile                String?
  externalOfficeFile          String?
  deparatureDate              DateTime?
  finalDestinationDate        DateTime?
  office                      String?
  visaNumber                  String?
  nationalidNumber            String?   @db.VarChar(25)
  KingdomentryTime            String?   @db.VarChar(30)
  deparatureTime              String?   @db.VarChar(30)
  finalDestinationTime        String?   @db.VarChar(30)
  startWoringDate             DateTime?
  DeparatureFromSaudiCity     String?   @db.VarChar(100)
  ArrivalOutSaudiCity         String?   @db.VarChar(100)
  DeparatureFromSaudiDate     DateTime?
  DeparatureFromSaudiTime     String?   @db.VarChar(100)
  createdAt                   DateTime? @default(now()) @db.DateTime(0)
  updatedAt                   DateTime? @updatedAt @db.DateTime(0)
  travelPermit                String?   @db.VarChar(522)
  travelPermitDate            DateTime? @db.DateTime(0)
  foreignLaborApproval        Boolean   @default(false)
  foreignLaborApprovalDate    DateTime? @db.DateTime(0)
  medicalCheckDate            DateTime? @db.DateTime(0)
  internalReason              String?   @db.VarChar(255)
  externalReason              String?   @db.VarChar(255)
  deparatureCityCountry       String?   @db.VarChar(255)
  deparatureCityCountryDate   DateTime? @db.DateTime(0)
  deparatureCityCountryTime   String?   @db.VarChar(150)
  internaldeparatureCity      String?   @db.VarChar(255)
  internaldeparatureDate      DateTime? @db.DateTime(0)
  internaldeparatureTime      String?   @db.VarChar(100)
  internalArrivalCity         String?   @db.VarChar(255)
  internalArrivalCityDate     DateTime? @db.DateTime(0)
  internalArrivalCityTime     String?   @db.VarChar(255)
  externaldeparatureCity      String?   @db.VarChar(90)
  externaldeparatureDate      DateTime? @db.DateTime(0)
  externaldeparatureTime      String?   @db.VarChar(100)
  externalArrivalCity         String?   @db.VarChar(255)
  externalArrivalCityDate     DateTime? @db.DateTime(0)
  externalArrivalCityTime     String?   @db.VarChar(100)
  startWorkingDate            DateTime? @db.DateTime(0)
  endWorkingDate              DateTime? @db.DateTime(0)
  guaranteeStatus             String?   @db.VarChar(255)
  deparatureTicketFile        String?   @db.VarChar(522)
  internalTicketFile          String?   @db.VarChar(255)
  /// ///
  VisaFile                    String?   @db.VarChar(522)
  receiptMethod               String?   @db.VarChar(50)
  externalTicketFile          String?   @db.VarChar(512)
  arrivalSaudiAirport         String?   @db.VarChar(255)
  customTimelineStages        Json?
  Order                       neworder? @relation(fields: [OrderId], references: [id])
  Sponsor                     Client?   @relation(fields: [SponsorIdnumber], references: [id])

  @@index([KingdomentryDate], map: "KingdomentryDate")
  @@index([OrderId], map: "OrderId")
  @@index([OrderId], map: "OrderId_2")
  @@index([PassportNumber], map: "PassportNumber")
  @@index([SponsorName], map: "SponsorName")
  @@index([arrivalSaudiAirport], map: "arrivalSaudiAirport")
  @@index([SponsorIdnumber], map: "arrivallist_SponsorIdnumber_fkey")
}

model minimumm {
  id        Int       @id @default(autoincrement())
  amount    Decimal?  @db.Decimal(10, 2)
  createdAt DateTime? @default(now()) @db.DateTime(0)
}

model transferSponsorShips {
  id                      Int       @id @default(autoincrement())
  HomeMaidId              Int?
  NewClientId             Int?
  OldClientId             Int?
  EntryDate               DateTime? @db.DateTime(0)
  Cost                    Decimal?  @db.Decimal(10, 2)
  Paid                    Decimal?  @db.Decimal(10, 2)
  ExperimentStart         DateTime? @db.DateTime(0)
  ExperimentEnd           DateTime? @db.DateTime(0)
  ExperimentDuration      String?   @db.VarChar(100)
  TransferOperationNumber String?   @db.VarChar(100)
  ContractDate            DateTime? @db.DateTime(0)
  ExperimentRate          String?   @db.VarChar(255)
  Notes                   String?   @db.Text
  WorkDuration            String?   @db.VarChar(255)
  NationalID              String?   @db.VarChar(255)
  TransferingDate         String?   @db.VarChar(255)
  file                    String?   @db.VarChar(255)
  transferStage           String?   @db.VarChar(255)
  createdAt               DateTime? @default(now()) @db.DateTime(0)
  updatedAt               DateTime? @default(now()) @updatedAt @db.DateTime(0)

  @@index([HomeMaidId])
  @@index([NewClientId])
  @@index([OldClientId])
}

model professions {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gender    String?  @db.VarChar(50)
}

model transactions {
  transaction_id   Int       @id @default(autoincrement())
  order_id         Int?
  Details          String?   @db.VarChar(100)
  amount           Decimal?  @db.Decimal(10, 2)
  transaction_type String?   @db.VarChar(255)
  transaction_date DateTime? @default(now()) @db.DateTime(0)

  @@index([order_id], map: "order_id")
}

model housedworker {
  id                      Int                 @id @default(autoincrement())
  homeMaid_id             Int?                @unique(map: "homeMaid_id")
  Details                 String?             @db.VarChar(255)
  houseentrydate          DateTime?           @db.DateTime(0)
  transaction_type        String?             @db.VarChar(255)
  deliveryDate            DateTime?           @db.DateTime(0)
  employee                String?             @db.VarChar(100)
  Reason                  String?             @db.VarChar(255)
  checkIns_id             Int?
  status                  String?             @db.VarChar(100)
  isActive                Boolean             @default(true)
  deparatureReason        String?             @db.VarChar(100)
  deparatureHousingDate   DateTime?           @db.DateTime(0)
  transferSponsorshipData Json?
  createdAt               DateTime?           @default(now()) @db.Timestamp(0)
  updatedAt               DateTime?           @default(now()) @updatedAt @db.Timestamp(0)
  location_id             Int
  isHasEntitlements       Boolean?            @default(false)
  entitlementsCost        Decimal?            @db.Decimal(10, 2)
  entitlementReason       String?             @db.VarChar(255)
  isExternal              Boolean             @default(false)
  externalHomedmaidId     Int?
