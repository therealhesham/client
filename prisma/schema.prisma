generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model homemaid {
  id                     Int       @id @default(autoincrement())
  OfficeName             String?   @db.VarChar(100)
  Externalofficecopy     String?   @db.VarChar(40)
  Name                   String?   @db.VarChar(1024)
  Nationalitycopy        String?   @db.VarChar(1024)
  Religion               String?   @db.VarChar(1024)
  maritalstatus          String?   @db.VarChar(1024)
  children               Int?
  weight                 Int?
  height                 Int?
  Education              String?   @db.VarChar(27)
  Experience             String?   @db.VarChar(1024)
  ExperienceYears        String?   @db.VarChar(1024)
  ExperiencePlaces       String?   @db.VarChar(51)
  Passportnumber         String?   @db.VarChar(1024)
  PassportEnd            DateTime? @db.DateTime(0)
  PassportStart          DateTime? @db.DateTime(0)
  OldPeopleCare          Int?      @db.TinyInt
  ArabicLanguageLevel    String?   @db.VarChar(522)
  EnglishLanguageLevel   String?   @db.VarChar(522)
  Salary                 String?   @db.VarChar(20)
  LaundryLevel           String?   @db.VarChar(522)
  IroningLevel           String?   @db.VarChar(522)
  CleaningLevel          String?   @db.VarChar(522)
  CookingLevel           String?   @db.VarChar(522)
  SewingLevel            String?   @db.VarChar(522)
  BabySitterLevel        String?   @db.VarChar(522)
  dateofbirth            DateTime? @db.DateTime(0)
  ages                   String?   @db.VarChar(1024)
  clientphonenumber      String?   @db.VarChar(19)
  phone                  String?   @db.VarChar(1024)
  officeID               Int?
  Picture                Json?
  Nationality            Json?
  age                    Int?
  flag                   Json?
  bookingstatus          String?   @db.VarChar(1024)
  experienceType         String?   @db.VarChar(100)
  FullPicture            Json?
  professionId           Int?
  displayOrder           Int       @default(0)
  job                    String?   @db.VarChar(32)
  createdAt              DateTime  @default(now()) @db.DateTime(0)
  updatedAt              DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  isExternal             Boolean   @default(false)
  Passportphoto          String?   @db.VarChar(522)
  transferSponsorShipsId Int?
  washingLevel           String?   @db.VarChar(100)
  childcareLevel         String?   @db.VarChar(100)
  elderlycareLevel       String?   @db.VarChar(100)
  isApproved             Boolean   @default(false)
  contractType           String    @default("recruitment") @db.VarChar(124)
  notes                  String?   @db.VarChar(255)
}

model tasks {
  id              Int       @id @default(autoincrement())
  userId          Int
  description     String    @db.Text
  taskDeadline    DateTime  @db.DateTime(0)
  createdAt       DateTime  @default(now()) @db.DateTime(0)
  updatedAt       DateTime  @default(now()) @updatedAt @db.DateTime(0)
  isCompleted     Boolean?  @default(false)
  Title           String?   @db.VarChar(255)
  assignedBy      Int?
  priority        String?   @db.VarChar(50)
  isActive        Boolean?  @default(true)
  isRepeating     Boolean?  @default(false)
  repeatType      String?   @db.VarChar(20)
  repeatInterval  Int?      @default(1)
  repeatStartDate DateTime? @db.DateTime(0)
  repeatEndDate   DateTime? @db.DateTime(0)
  repeatEndType   String?   @db.VarChar(20)
  repeatCount     Int?      @default(1)
  repeatDays      Json?
  repeatTime      String?   @db.VarChar(10)
  completionDate  DateTime? @db.DateTime(0)
  completionNotes String?   @db.VarChar(500)
  parentTaskId    Int?
  notificationsId Int?
}

model notifications {
  id                String    @id @db.VarChar(50)
  user_id           String?   @db.VarChar(50)
  title             String?   @db.VarChar(150)
  message           String?   @db.Text
  notification_type String?   @db.VarChar(50)
  is_unread         Boolean?  @default(true)
  created_at        DateTime? @default(now()) @db.Timestamp(0)

  @@index([user_id], map: "user_id")
}

model officemssages {
  id         Int       @id @default(autoincrement())
  title      String?   @db.VarChar(55)
  message    String?   @db.VarChar(255)
  createdAt  DateTime? @default(now()) @db.DateTime(0)
  updatedAt  DateTime? @default(now()) @updatedAt @db.DateTime(0)
  isRead     Boolean?  @default(false)
  officeName String?
  sender     String?   @db.VarChar(255)
  type       String    @db.VarChar(32)
}

model offices {
  id                        Int      @id @default(autoincrement())
  office                    String?  @unique(map: "office") @db.VarChar(512)
  Country                   String?  @db.VarChar(512)
  phoneNumber               String?
  password                  String?  @db.VarChar(255)
  office_id                 String?  @db.VarChar(255)
  url                       String?  @db.VarChar(512)
  musanadFinancialRecordsId Int?
  email                     String?
  language                  String   @default("eng") @db.VarChar(151)
  commission                Decimal? @default(0.000000000000000000000000000000)
}

model notes {
  id        Int      @id @default(autoincrement())
  notes     String?  @db.VarChar(255)
  clientID  Int?
  createdAt DateTime @default(now()) @db.DateTime(0)
  updatedAt DateTime @updatedAt @db.DateTime(0)
}

model logs {
  id         Int       @id @default(autoincrement())
  Status     String?   @db.VarChar(255)
  createdAt  DateTime? @default(now()) @db.DateTime(0)
  updatedAt  DateTime? @default(now()) @updatedAt @db.DateTime(0)
  Details    String?   @db.Text
  reason     String?   @db.Text
  userId     String?   @db.VarChar(255)
  homemaidId Int?
}

model neworder {
  id                       Int           @id @default(autoincrement())
  ClientName               String?       @db.VarChar(255)
  PhoneNumber              String?       @db.VarChar(15)
  clientID                 Int?
  HomemaidId               Int?
  Nationalitycopy          String?       @db.VarChar(255)
  Name                     String?       @db.VarChar(255)
  Religion                 String?       @db.VarChar(255)
  Passportnumber           String?       @db.VarChar(255)
  clientphonenumber        String?       @db.VarChar(255)
  Picture                  Json?
  ExperienceYears          String?       @db.VarChar(255)
  maritalstatus            String?       @db.VarChar(255)
  Experience               String?       @db.VarChar(255)
  dateofbirth              String?       @db.VarChar(255)
  Nationality              Json?
  age                      Int?
  flag                     Json?
  phone                    String?       @db.VarChar(15)
  bookingstatus            String?       @db.VarChar(255)
  ages                     String?       @db.VarChar(255)
  createdAt                DateTime?     @default(now())
  updatedAt                DateTime?     @updatedAt
  updatedBy                String?       @db.VarChar(255)
  ReasonOfRejection        String?       @db.VarChar(255)
  HomemaidIdCopy           Int?
  nationalId               String?       @db.VarChar(30)
  profileStatus            String?       @db.VarChar(255)
  isHidden                 Boolean       @default(false)
  typeOfContract           String        @default("recruitment") @db.VarChar(23)
  PaymentMethod            String?       @db.VarChar(32)
  Installments             Int?
  Total                    Float?
  isContractEnded          Boolean       @default(false)
  orderDocument            String?       @db.VarChar(522)
  contract                 String?       @db.VarChar(522)
  isAvailable              Boolean       @default(true)
  paid                     Float?
  notes                    String?       @db.VarChar(255)
  DeliveryDetailsId        Int?
  clientAccountStatementId Int?
  visaId                   Int?
  ReasonOfCancellation     String?       @db.VarChar(255)
  foreignLaborApproval     Boolean?      @default(false)
  travelPermit             String?       @db.VarChar(255)
  medicalCheckFile         String?
  clientBookingStatus      String?       @default("new_order") @db.VarChar(255)
  arrivals                 arrivallist[]
  visa                     visa?         @relation(fields: [visaId], references: [id])

  @@index([visaId])
}

model visa {
  id          Int        @id @default(autoincrement())
  visaNumber  String?    @db.VarChar(255)
  gender      String?    @db.VarChar(255)
  profession  String?    @db.VarChar(255)
  visaFile    String?    @db.VarChar(512)
  nationality String?    @db.VarChar(255)
  clientID    Int?
  createdAt   DateTime?  @default(now()) @db.DateTime(0)
  updatedAt   DateTime?  @default(now()) @updatedAt @db.DateTime(0)
  orders      neworder[]
}

model emaillist {
  id         Int       @id @default(autoincrement())
  email      String?
  department String?
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
  userId     Int?
}

model arrivallist {
  id                          Int       @id @default(autoincrement())
  SponsorName                 String?
  InternalmusanedContract     String?
  SponsorIdnumber             Int?
  SponsorPhoneNumber          String?   @db.VarChar(15)
  PassportNumber              String?
  KingdomentryDate            DateTime?
  DayDate                     DateTime? @default(now())
  WorkDuration                String?
  Cost                        String?
  HomemaIdnumber              Int?
  HomemaidName                String?
  Notes                       String?
  DateOfApplication           DateTime?
  MusanadDuration             String?
  ExternalDateLinking         DateTime?
  ExternalOFficeApproval      DateTime?
  AgencyDate                  DateTime?
  EmbassySealing              DateTime?
  BookinDate                  DateTime?
  GuaranteeDurationEnd        DateTime?
  medicalCheckFile            String?
  ticketFile                  String?
  visaIssuanceDate            DateTime?
  receivingFile               String?
  approvalPayment             String?
  additionalfiles             Json?
  OrderId                     Int?
  externalmusanedContract     String?
  externalmusanadcontractfile String?
  externalOfficeStatus        String?   @db.VarChar(25)
  DeliveryDate                DateTime?
  ExternalStatusByoffice      String?
  DeliveryFile                String?
  externalOfficeFile          String?
  office                      String?
  visaNumber                  String?
  nationalidNumber            String?   @db.VarChar(25)
  KingdomentryTime            String?   @db.VarChar(30)
  createdAt                   DateTime? @default(now())
  updatedAt                   DateTime? @updatedAt
  travelPermit                String?
  travelPermitDate            DateTime?
  foreignLaborApproval        Boolean?  @default(false)
  foreignLaborApprovalDate    DateTime?
  medicalCheckDate            DateTime?
  internalReason              String?
  externalReason              String?
  deparatureCityCountry       String?
  deparatureCityCountryDate   DateTime?
  deparatureCityCountryTime   String?
  internaldeparatureCity      String?
  internaldeparatureDate      DateTime?
  internaldeparatureTime      String?
  internalArrivalCity         String?
  internalArrivalCityDate     DateTime?
  internalArrivalCityTime     String?   @db.VarChar(30)
  externaldeparatureCity      String?
  externaldeparatureDate      DateTime?
  externaldeparatureTime      String?
  externalArrivalCity         String?
  externalArrivalCityDate     DateTime?
  externalArrivalCityTime     String?   @db.VarChar(30)
  startWorkingDate            DateTime?
  endWorkingDate              DateTime?
  guaranteeStatus             String?   @db.VarChar(100)
  deparatureTicketFile        String?   @db.VarChar(255)
  internalTicketFile          String?   @db.VarChar(255)
  /// ///
  VisaFile                    String?   @db.VarChar(522)
  receiptMethod               String?   @db.VarChar(50)
  externalTicketFile          String?   @db.VarChar(255)
  arrivalSaudiAirport         String?
  customTimelineStages        Json?
  deliveryOfficer             String?
  ArrivalCity                 String?
  finaldestination            String?
  deparatureDate              DateTime?
  finalDestinationDate        DateTime?
  deparatureTime              String?   @db.VarChar(30)
  finalDestinationTime        String?   @db.VarChar(30)
  startWoringDate             DateTime?
  DeparatureFromSaudiCity     String?   @db.VarChar(100)
  ArrivalOutSaudiCity         String?   @db.VarChar(100)
  DeparatureFromSaudiDate     DateTime?
  DeparatureFromSaudiTime     String?   @db.VarChar(100)
  Order                       neworder? @relation(fields: [OrderId], references: [id])
  Sponsor                     client?   @relation(fields: [SponsorIdnumber], references: [id])

  @@index([OrderId], map: "OrderId")
  @@index([OrderId], map: "OrderId_2")
  @@index([SponsorIdnumber], map: "arrivallist_SponsorIdnumber_fkey")
}

model minimumm {
  id        Int       @id @default(autoincrement())
  amount    Decimal?  @db.Decimal(10, 2)
  createdAt DateTime? @default(now()) @db.DateTime(0)
}

model professions {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gender    String?  @db.VarChar(50)
}

model transactions {
  transaction_id   Int       @id @default(autoincrement())
  order_id         Int?
  Details          String?   @db.VarChar(100)
  amount           Decimal?  @db.Decimal(10, 2)
  transaction_type String?   @db.VarChar(255)
  transaction_date DateTime? @default(now()) @db.DateTime(0)
}

model housedworker {
  id                      Int                @id @default(autoincrement())
  homeMaid_id             Int?               @unique(map: "homeMaid_id")
  Details                 String?            @db.VarChar(255)
  houseentrydate          DateTime?          @db.DateTime(0)
  transaction_type        String?            @db.VarChar(255)
  deliveryDate            DateTime?          @db.DateTime(0)
  employee                String?            @db.VarChar(100)
  Reason                  String?            @db.VarChar(255)
  checkIns_id             Int?
  status                  String?            @db.VarChar(100)
  isActive                Boolean            @default(true)
  deparatureReason        String?            @db.VarChar(100)
  deparatureHousingDate   DateTime?          @db.DateTime(0)
  transferSponsorshipData Json?
  createdAt               DateTime?          @default(now()) @db.Timestamp(0)
  updatedAt               DateTime?          @default(now()) @updatedAt @db.Timestamp(0)
  location_id             Int
  isHasEntitlements       Boolean?           @default(false)
  entitlementsCost        Decimal?           @db.Decimal(10, 2)
  entitlementReason       String?            @db.VarChar(255)
  isExternal              Boolean            @default(false)
  externalHomedmaidId     Int?
  externalHomedmaid       externalhomedmaid? @relation(fields: [externalHomedmaidId], references: [id])

  @@index([externalHomedmaidId])
}

model income {
  transaction_id   Int       @id @default(autoincrement())
  order_id         Int?
  Details          String?   @db.VarChar(100)
  amount           Decimal?  @db.Decimal(10, 2)
  transaction_type String?   @db.VarChar(255)
  transaction_date DateTime? @default(now()) @db.DateTime(0)
}

model admins {
  id       Int    @id @default(autoincrement())
  username String @unique(map: "username") @db.VarChar(50)
  password String @db.VarChar(255)
}

model display_order_sequence {
  id             Int       @id @default(autoincrement())
  sequence_value Int       @default(0)
  updated_at     DateTime? @default(now()) @db.Timestamp(0)
}

model links {
  id           Int       @id @default(autoincrement())
  original_url String    @db.VarChar(255)
  short_code1  String    @unique(map: "short_code1") @db.VarChar(10)
  short_code2  String    @unique(map: "short_code2") @db.VarChar(10)
  created_at   DateTime? @default(now()) @db.Timestamp(0)
  utm_source   String?   @db.VarChar(255)
  utm_medium   String?   @db.VarChar(255)
  utm_campaign String?   @db.VarChar(255)
  utm_term     String?   @db.VarChar(255)
  utm_content  String?   @db.VarChar(255)
}

model percentage {
  id               Int      @id @default(autoincrement())
  malePercentage   Decimal? @db.Decimal(10, 2)
  femalePercentage Decimal? @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())
}

model tickets_details {
  id                Int       @id @default(autoincrement())
  order_id          Int?
  createdAt         DateTime? @default(now()) @db.DateTime(0)
  updatedAt         DateTime? @default(now()) @db.DateTime(0)
  ticketFile        String?   @db.VarChar(1024)
  reference_id      String?   @db.VarChar(1024)
  airlines          String?   @db.VarChar(1024)
  flight_number     String?   @db.VarChar(1024)
  departure_date    DateTime? @db.DateTime(0)
  departure_time    String?   @db.VarChar(1024)
  arrival_date      DateTime? @db.DateTime(0)
  arrival_time      String?   @db.VarChar(1024)
  departure_airport String?   @db.VarChar(1024)
  arrival_airport   String?   @db.VarChar(1024)
}

model accountsystemlogs {
  id             Int       @id @default(autoincrement())
  action         String?
  actionNotes    String?
  actionType     String?
  actionStatus   String?
  actionAmount   Decimal?
  actionClientId Int?
  actionUserId   Int?
  createdAt      DateTime? @default(now())
  updatedAt      DateTime?

  @@index([actionClientId], map: "idx_actionClientId")
  @@index([actionUserId], map: "idx_actionUserId")
}

model attachments {
  id             String    @id @db.VarChar(50)
  case_id        String?   @db.VarChar(50)
  transaction_id String?   @db.VarChar(50)
  name           String    @db.VarChar(255)
  file_type      String?   @db.VarChar(50)
  file_size      String?   @db.VarChar(50)
  file_url       String?   @db.Text
  uploaded_at    DateTime? @default(now()) @db.Timestamp(0)
  violation_id   String?   @db.VarChar(50)

  @@index([case_id], map: "case_id")
  @@index([violation_id], map: "idx_violation_id")
}

model audit_logs {
  id            String    @id @db.VarChar(50)
  user_id       String?   @db.VarChar(50)
  user_name     String?   @db.VarChar(100)
  action_type   String?   @db.VarChar(100)
  details       String?   @db.Text
  log_timestamp DateTime? @default(now()) @db.DateTime(0)
  user_role     String?   @db.VarChar(50)

  @@index([user_id], map: "user_id")
}

model automaticemployee {
  id                Int      @id @default(autoincrement())
  name              String?
  age               String?
  religion          String?
  maritalStatus     String?
  birthDate         String?
  nationality       String?
  officeName        String?
  passportNumber    String?
  passportStartDate String?
  passportEndDate   String?
  contractDuration  String?
  weight            Int?
  height            Int?
  salary            String?
  lang_english      String?  @db.VarChar(50)
  lang_arabic       String?  @db.VarChar(50)
  skill_washing     String?  @db.VarChar(50)
  skill_cooking     String?  @db.VarChar(50)
  skill_babysetting String?  @db.VarChar(50)
  skill_cleaning    String?  @db.VarChar(50)
  skill_laundry     String?  @db.VarChar(50)
  profileImage      String?  @db.VarChar(500)
  fullImage         String?  @db.VarChar(500)
  createdAt         DateTime @default(now())
  updatedAt         DateTime
}

model cancelledorders {
  id                   Int       @id @default(autoincrement())
  order_id             Int
  HomeMaidId           Int?
  ReasonOfCancellation String?   @db.VarChar(2048)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime
  clientId             Int?
  CancellationDate     DateTime?

  @@map("cancelledOrders")
}

model cases {
  id                String    @id @db.VarChar(50)
  case_no           String    @unique(map: "case_no") @db.VarChar(50)
  court_type        String?   @db.VarChar(150)
  case_type         String?   @db.VarChar(150)
  first_party       String?   @db.VarChar(255)
  second_party      String?   @db.VarChar(255)
  status            String?   @db.VarChar(50)
  next_session_date DateTime? @db.Date
  next_session_time DateTime? @db.Time(0)
  created_at        DateTime? @default(now()) @db.Timestamp(0)
  deleted_at        DateTime? @db.Timestamp(0)
  final_judgment    String?   @db.Text
  execution_status  String?   @db.VarChar(255)
  execution_notes   String?   @db.Text
}

model cash {
  id               Int       @id @default(autoincrement())
  createdAt        DateTime? @default(now())
  updatedAt        DateTime?
  amount           Decimal?
  transaction_type String?   @db.VarChar(100)
  Month            String?   @db.VarChar(100)
  Year             String?   @db.VarChar(100)
}

model cashlogs {
  id        Int       @id @default(autoincrement())
  Status    String?   @db.VarChar(255)
  createdAt DateTime? @default(now())
  updatedAt DateTime?
  userId    String?
  cashID    Int?
}

model checkin {
  id              Int       @id @default(autoincrement())
  housedWorkerId  Int
  breakfastOption String?   @db.VarChar(255)
  breakfastNotes  String?   @db.VarChar(255)
  lunchOption     String?   @db.VarChar(255)
  lunchNotes      String?   @db.VarChar(255)
  supperOption    String?   @db.VarChar(255)
  supperNotes     String?   @db.VarChar(255)
  complaint       String?   @db.VarChar(255)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  cost            String?
  lunchCost       Int?
  breakfastCost   Int?
  supperCost      Int?
  CheckDate       DateTime?
  isActive        Boolean?  @default(true)
  DailyCost       Decimal?
}

model client {
  id            Int           @id @default(autoincrement())
  isUser        Boolean?
  fullname      String?
  notes_date    DateTime?
  email         String?       @unique(map: "email")
  phonenumber   String?       @unique(map: "phonenumber") @db.VarChar(15)
  password      String?
  HomeMaidRecod Int?
  Source        String?
  createdAt     DateTime?     @default(now())
  nationalId    String?       @db.VarChar(30)
  city          String?       @db.VarChar(100)
  address       String?       @db.VarChar(100)
  arrivals      arrivallist[]

  @@map("Client")
}

model clientaccountentry {
  id           Int      @id @default(autoincrement())
  statementId  Int
  date         DateTime
  description  String   @db.VarChar(500)
  debit        Decimal  @default(0.000000000000000000000000000000)
  credit       Decimal  @default(0.000000000000000000000000000000)
  balance      Decimal  @default(0.000000000000000000000000000000)
  entryType    String?  @db.VarChar(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  isEditable   Boolean?
  displayOrder Int?     @default(0)
}

model clientaccountstatement {
  id                   Int      @id @default(autoincrement())
  clientId             Int
  contractNumber       String?  @db.VarChar(255)
  officeName           String?  @db.VarChar(255)
  totalRevenue         Decimal  @default(0.000000000000000000000000000000)
  totalExpenses        Decimal  @default(0.000000000000000000000000000000)
  netAmount            Decimal  @default(0.000000000000000000000000000000)
  contractStatus       String?  @db.VarChar(100)
  notes                String?  @db.VarChar(500)
  createdAt            DateTime @default(now())
  updatedAt            DateTime
  orderId              Int?
  commissionPercentage Decimal? @default(0.000000000000000000000000000000)
  masandTransferAmount Decimal? @default(0.000000000000000000000000000000)
  attachment           String?  @db.VarChar(500)
}

model complaint {
  id              Int       @id @default(autoincrement())
  title           String?   @db.VarChar(255)
  description     String?   @db.Text
  screenshot      String?   @db.VarChar(1024)
  status          String    @default("pending") @db.VarChar(50)
  createdById     Int
  assignedToId    Int?
  resolutionNotes String?   @db.Text
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime

  @@index([assignedToId], map: "fk_complaint_assigned_to")
  @@index([createdById], map: "fk_complaint_created_by")
  @@index([status], map: "idx_complaint_status")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model customtimeline {
  id        Int      @id @default(autoincrement())
  name      String?  @db.VarChar(255)
  stages    Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
  officeId  Int

  @@map("CustomTimeline")
}

model deliverydetails {
  id             Int       @id @default(autoincrement())
  deliveryDate   DateTime?
  deliveryTime   String?   @db.VarChar(100)
  deliveryFile   String?   @db.VarChar(255)
  deliveryNotes  String?   @db.VarChar(255)
  cost           Decimal?
  newOrderId     Int?
